{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "Product details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "sellingPrice": { "type": "number" }
      }
    },
    "Tax": {
      "title": "Tax",
      "description": "Tax detail",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "percentage": { "type": "number" },
        "active": { "type": "boolean" }
      }
    },
    "FixedCost": {
      "title": "FixedCost",
      "description": "Fixed monthly cost details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "monthlyValue": { "type": "number" }
      }
    },
    "Recipe": {
      "title": "Recipe",
      "description": "Recipe with ingredients",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "productId": { "type": "string" },
        "name": { "type": "string" }
      }
    },
    "Sale": {
      "title": "Sale",
      "description": "Recorded POS/PDV sale transaction",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string" },
        "paymentMethod": { "type": "string" },
