        "totalCost": { "type": "number" },
        "taxesAmount": { "type": "number" },
        "netProfit": { "type": "number" }
      }
    }
  },
  "firestore": {
    "products": {
      "schema": "Product",
      "description": "Store products"
    },
    "taxes": {
      "schema": "Tax",
      "description": "Store taxes config"
    },
    "fixedCosts": {
      "schema": "FixedCost",
      "description": "Store monthly fixed costs"
    },
    "recipes": {
      "schema": "Recipe",
      "description": "Store product recipes"
    },
    "sales": {
      "schema": "Sale",
      "description": "Store off-iFood sales from PDV"
    }
