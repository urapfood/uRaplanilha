rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net default deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSystemAdmin() {
      return request.auth != null && (
        request.auth.uid == '8YlD3mzPgpXZpOxAhwEKEviiaCt1' ||
        ('email' in request.auth.token && (
          request.auth.token.email == 'urapfood@gmail.com' ||
          request.auth.token.email == 'sistema-u-raplanilha-backend@uraplanilha.com'
        ))
      );
    }

    match /webhookLogs/{document} {
      allow read: if isSystemAdmin();
      allow write: if isSystemAdmin() || request.auth == null;
    }

    match /feedbacks/{document} {
      allow read: if isSystemAdmin() || (request.auth != null && resource.data.userId == request.auth.uid);
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSystemAdmin();
    }

    match /users/{userId} {
      allow read: if (request.auth != null && request.auth.uid == userId) || isSystemAdmin() || request.auth == null;
      allow create: if (request.auth != null && request.auth.uid == userId) || isSystemAdmin() || request.resource.data.isBackendUpdate == true;
      allow update: if isSystemAdmin() || (
        request.auth != null && request.auth.uid == userId &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['licenseStatus', 'licenseExpiresAt', 'asaasCustomerId', 'asaasPaymentId', 'asaasPaymentUrl'])
      ) || (
        request.resource.data.isBackendUpdate == true
      );
    }

    match /users/{userId}/{subcollection=**} {
      allow read, write: if (request.auth != null && request.auth.uid == userId) || isSystemAdmin();
    }
  }
}
